generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LaunchPlan {
  starter
  growth
  global
}

enum ApplicationStatus {
  draft
  submitted
  in_review
  approved
  needs_action
  rejected
}

enum FormationState {
  delaware
  wyoming
  new_mexico
  florida
}

enum Industry {
  software_saas
  freelancing
  ecommerce
  consulting
  marketing_agency
  crypto_web3
  other
}

enum RevenueBand {
  below_5k
  between_5k_50k
  above_50k
}

enum BusinessModel {
  saas
  freelancing
  ecommerce
  marketplace
  agency
}

enum CustomerRegion {
  usa
  europe
  global
}

enum PaymentMethod {
  ach
  card_payments
  wire_transfers
  virtual_cards
}

enum DocumentType {
  passport_id
  proof_of_address
  ein_letter
  formation_certificate
  operating_agreement
}

enum DocumentStatus {
  pending_upload
  uploaded
  generated
}

enum BusinessAddressMode {
  priyo_registered_address
  custom
}

model User {
  id                  String        @id @default(cuid())
  name                String
  email               String        @unique
  phone               String
  country             String?
  dateOfBirth         DateTime?
  citizenshipCountry  String?
  residenceCountry    String?
  residentialAddress  Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  applications        Application[]
}

model Application {
  id                   String             @id @default(cuid())
  userId               String
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName          String
  altCompanyName       String?
  stateOfFormation     FormationState?
  industry             Industry?
  businessDescription  String?
  businessWebsite      String?
  status               ApplicationStatus  @default(draft)
  selectedPlan         LaunchPlan         @default(growth)
  currentStep          Int                @default(1)
  draftToken           String             @unique
  submittedAt          DateTime?
  numberOfOwners       Int?
  soleOwner            Boolean            @default(true)
  businessAddressMode  BusinessAddressMode @default(priyo_registered_address)
  businessAddress      Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  owners               Owner[]
  services             ServiceSelection?
  documents            Document[]
  payment              Payment?
}

model Owner {
  id                   String       @id @default(cuid())
  applicationId        String
  application          Application  @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  name                 String
  ownershipPercentage  Float
  citizenshipCountry   String
  address              Json
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
}

model ServiceSelection {
  id                     String           @id @default(cuid())
  applicationId          String           @unique
  application            Application      @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  einFiling              Boolean          @default(false)
  registeredAgent        Boolean          @default(false)
  businessAddress        Boolean          @default(false)
  complianceMonitoring   Boolean          @default(false)
  priyoPayAccount        Boolean          @default(false)
  expectedMonthlyRevenue RevenueBand?
  businessModel          BusinessModel?
  customerRegions        CustomerRegion[]
  paymentMethods         PaymentMethod[]
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt
}

model Document {
  id              String         @id @default(cuid())
  applicationId   String
  application     Application    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  type            DocumentType
  fileName        String
  mimeType        String
  size            Int
  storageKey      String?
  storageBucket   String?
  uploadStatus    DocumentStatus @default(pending_upload)
  uploadedAt      DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@unique([applicationId, type])
}

model Payment {
  id             String      @id @default(cuid())
  applicationId  String      @unique
  application    Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  plan           LaunchPlan
  amount         Int
  currency       String      @default("USD")
  paymentStatus  String      @default("pending")
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

